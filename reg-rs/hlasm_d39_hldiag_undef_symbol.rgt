command = "cor24-run --run hlasm.s --load-binary demos/d39_hldiag_undef_symbol.bin@524288 --speed 0 -n 150000 2>&1"
timeout = 15
preprocess = "grep -A 120 '^UART output:' || true"
exit_code = 0
desc = "Demo 39: HLDIAG emits an end-of-run warning per distinct SET/EQU-expression symbol that was looked up but never defined"

command = "cor24-run --run hlasm.s --load-binary demos/d17_multi_buffer_main.bin@524288 --load-binary demos/d17_multi_buffer_extra.bin@528384 --load-binary reg-rs/s9_multibuf.cfg@520192 --speed 0 -n 100000 2>&1"
timeout = 15
preprocess = "grep -A 100 '^UART output:' || true"
exit_code = 0
desc = "Demo 17: multi-buffer source input with cross-buffer macro/symbol state"

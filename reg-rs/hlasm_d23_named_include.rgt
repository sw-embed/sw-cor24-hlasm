command = 'bash reg-rs/run_bootstrap_sourceset.sh demos/d23_named_include.sourceset 120000 2>&1'
timeout = 15
preprocess = "grep -A 100 '^UART output:' || true"
exit_code = 0
desc = 'Demo 23: INCLUDE resolves a named include table entry and resumes the patched main source after include EOF via composed source-set fragments'

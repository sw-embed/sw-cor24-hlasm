command = 'cor24-run --run hlasm.s --load-binary demos/d23_named_include_main.bin@589824 --load-binary demos/d23_named_include_extra.bin@528384 --load-binary reg-rs/s15_named_include.cfg@520192 --stack-kilobytes 3 --speed 0 -n 120000 2>&1'
timeout = 15
preprocess = "grep -A 100 '^UART output:' || true"
exit_code = 0
desc = 'Demo 23: INCLUDE resolves a named include table entry and resumes the patched main source after include EOF'

command = "cor24-run --run hlasm.s --load-binary demos/d20_patched_main_main.bin@589824 --load-binary demos/d20_patched_main_extra.bin@528384 --load-binary reg-rs/s12_patched_main.cfg@520192 --stack-kilobytes 3 --speed 0 -n 120000 2>&1"
timeout = 15
preprocess = "grep -A 100 '^UART output:' || true"
exit_code = 0
desc = "Demo 20: main source base/length can be overridden from the source config block"
